{% import '_includes/forms.twig' as forms %}

{{ forms.lightswitchField({
    label: 'Enable popups',
    name: 'enabled',
    on: settings.enabled,
    errors: settings.getErrors('enabled')
}) }}

{{ forms.lightswitchField({
    label: 'Automatically inject frontend assets',
    instructions: 'When disabled, add {{ craft.popupPromoter.register() }} to your layout template.',
    name: 'autoInject',
    on: settings.autoInject,
    errors: settings.getErrors('autoInject')
}) }}

<hr>

{{ forms.selectField({
    label: 'Popup section',
    instructions: 'Only live entries from this section are considered. Disabled, pending, and expired entries are skipped.',
    name: 'sectionHandle',
    value: settings.sectionHandle,
    options: sections,
    errors: settings.getErrors('sectionHandle')
}) }}

<div class="field">
    <div class="heading">
        <label>Default content model</label>
        <div class="instructions">
            <p>Create a Popups section with description, image, call to action, and cancel button label fields, then map these settings automatically.</p>
        </div>
    </div>
    <button type="button" class="btn" data-cpp-install-defaults>Create default section + fields</button>
</div>

<hr>

{{ forms.selectField({
    label: 'Title field',
    instructions: 'Select Entry title or map a custom field.',
    name: 'titleFieldHandle',
    value: settings.titleFieldHandle,
    options: titleFields,
    errors: settings.getErrors('titleFieldHandle')
}) }}

{{ forms.selectField({
    label: 'Description field',
    name: 'descriptionFieldHandle',
    value: settings.descriptionFieldHandle,
    options: fields,
    errors: settings.getErrors('descriptionFieldHandle')
}) }}

{{ forms.selectField({
    label: 'Image field',
    name: 'imageFieldHandle',
    value: settings.imageFieldHandle,
    options: fields,
    errors: settings.getErrors('imageFieldHandle')
}) }}

{{ forms.selectField({
    label: 'Call to action URL field',
    name: 'ctaUrlFieldHandle',
    value: settings.ctaUrlFieldHandle,
    options: fields,
    errors: settings.getErrors('ctaUrlFieldHandle')
}) }}

{{ forms.selectField({
    label: 'Call to action label field',
    name: 'ctaLabelFieldHandle',
    value: settings.ctaLabelFieldHandle,
    options: fields,
    errors: settings.getErrors('ctaLabelFieldHandle')
}) }}

{{ forms.textField({
    label: 'Fallback call to action label',
    name: 'ctaLabelDefault',
    value: settings.ctaLabelDefault,
    errors: settings.getErrors('ctaLabelDefault')
}) }}

{{ forms.selectField({
    label: 'Cancel button text field',
    name: 'cancelLabelFieldHandle',
    value: settings.cancelLabelFieldHandle,
    options: fields,
    errors: settings.getErrors('cancelLabelFieldHandle')
}) }}

{{ forms.textField({
    label: 'Fallback cancel button text',
    name: 'cancelLabelDefault',
    value: settings.cancelLabelDefault,
    errors: settings.getErrors('cancelLabelDefault')
}) }}

{{ forms.selectField({
    label: 'Call to action target',
    name: 'ctaTarget',
    value: settings.ctaTarget,
    options: [
        { label: 'Same tab', value: '_self' },
        { label: 'New tab', value: '_blank' }
    ],
    errors: settings.getErrors('ctaTarget')
}) }}

{{ forms.textField({
    label: 'Call to action button color',
    name: 'buttonColor',
    value: settings.buttonColor,
    type: 'color',
    errors: settings.getErrors('buttonColor')
}) }}

{{ forms.textField({
    label: 'Cancel button color',
    name: 'cancelButtonColor',
    value: settings.cancelButtonColor,
    type: 'color',
    errors: settings.getErrors('cancelButtonColor')
}) }}

<hr>

{{ forms.selectField({
    label: 'Default variant',
    name: 'defaultVariant',
    value: settings.defaultVariant,
    options: variants,
    errors: settings.getErrors('defaultVariant')
}) }}

{{ forms.lightswitchField({
    label: 'Randomize variants',
    instructions: 'When enabled, each popup render randomly chooses one of the available variants.',
    name: 'randomizeVariants',
    on: settings.randomizeVariants,
    errors: settings.getErrors('randomizeVariants')
}) }}

{{ forms.textField({
    label: 'Delay before showing',
    instructions: 'Number of seconds to wait before opening the popup on the frontend.',
    name: 'delaySeconds',
    value: settings.delaySeconds,
    type: 'number',
    min: 0,
    max: 86400,
    errors: settings.getErrors('delaySeconds')
}) }}

<div class="field">
    <div class="heading">
        <label>Test modal</label>
        <div class="instructions">
            <p>Preview a random live entry from the selected section using the current mappings.</p>
        </div>
    </div>
    <button type="button" class="btn" data-cpp-test-modal>Test modal</button>
</div>

{{ forms.lightswitchField({
    label: 'Close on escape',
    name: 'closeOnEsc',
    on: settings.closeOnEsc,
    errors: settings.getErrors('closeOnEsc')
}) }}

{{ forms.lightswitchField({
    label: 'Close on backdrop click',
    name: 'closeOnBackdrop',
    on: settings.closeOnBackdrop,
    errors: settings.getErrors('closeOnBackdrop')
}) }}

{{ forms.textField({
    label: 'Cookie name prefix',
    name: 'cookieNamePrefix',
    value: settings.cookieNamePrefix,
    errors: settings.getErrors('cookieNamePrefix')
}) }}

{{ forms.textField({
    label: 'Cookie duration in days',
    instructions: 'Use 0 for a session cookie.',
    name: 'cookieDurationDays',
    value: settings.cookieDurationDays,
    type: 'number',
    min: 0,
    max: 3650,
    errors: settings.getErrors('cookieDurationDays')
}) }}

<div class="cpp-test-overlay" data-cpp-test-overlay hidden>
    <div class="cpp-test-shell" data-cpp-test-shell>
        <article class="cpp-test-card" role="dialog" aria-modal="true" aria-labelledby="cpp-test-title">
            <button class="cpp-test-close" type="button" aria-label="Close test modal" data-cpp-test-close>&times;</button>
            <div class="cpp-test-media" aria-hidden="true">
                <img alt="" data-cpp-test-image hidden>
                <span data-cpp-test-placeholder></span>
            </div>
            <div class="cpp-test-main">
                <p class="cpp-test-kicker">Promoted</p>
                <h2 id="cpp-test-title" class="cpp-test-title" data-cpp-test-title></h2>
                <p class="cpp-test-description" data-cpp-test-description></p>
                <div class="cpp-test-actions">
                    <button class="cpp-test-cta" type="button" data-cpp-test-cta></button>
                    <button class="cpp-test-cancel" type="button" data-cpp-test-cancel></button>
                </div>
            </div>
        </article>
    </div>
</div>

{% css %}
.cpp-test-overlay[hidden] {
    display: none;
}

.cpp-test-overlay {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    background: rgba(17, 24, 39, 0.58);
}

.cpp-test-shell {
    width: min(100%, 620px);
    color: #111827;
    background: #fff;
    border-radius: 8px;
    box-shadow: 0 24px 80px rgba(17, 24, 39, 0.28);
    overflow: hidden;
}

.cpp-test-overlay[data-variant="top"] {
    align-items: flex-start;
}

.cpp-test-overlay[data-variant="bottom"],
.cpp-test-overlay[data-variant="corner"] {
    align-items: flex-end;
}

.cpp-test-overlay[data-variant="left"] {
    align-items: stretch;
    justify-content: flex-start;
    padding: 0;
}

.cpp-test-overlay[data-variant="right"] {
    align-items: stretch;
    justify-content: flex-end;
    padding: 0;
}

.cpp-test-overlay[data-variant="full"] {
    align-items: stretch;
    justify-content: stretch;
    padding: 0;
}

.cpp-test-overlay[data-variant="corner"] {
    justify-content: flex-end;
}

.cpp-test-overlay[data-variant="top"] .cpp-test-shell,
.cpp-test-overlay[data-variant="bottom"] .cpp-test-shell {
    width: min(100%, 880px);
}

.cpp-test-overlay[data-variant="left"] .cpp-test-shell,
.cpp-test-overlay[data-variant="right"] .cpp-test-shell {
    width: min(92vw, 440px);
    min-height: 100vh;
    border-radius: 0;
}

.cpp-test-overlay[data-variant="full"] .cpp-test-shell {
    width: 100vw;
    min-height: 100vh;
    border-radius: 0;
}

.cpp-test-overlay[data-variant="corner"] .cpp-test-shell {
    width: min(100%, 420px);
}

.cpp-test-card {
    position: relative;
    display: grid;
    grid-template-columns: minmax(180px, 42%) minmax(0, 1fr);
    min-height: 100%;
    background: #fff;
}

.cpp-test-overlay[data-variant="left"] .cpp-test-card,
.cpp-test-overlay[data-variant="right"] .cpp-test-card,
.cpp-test-overlay[data-variant="full"] .cpp-test-card {
    grid-template-columns: 1fr;
}

.cpp-test-overlay[data-variant="full"] .cpp-test-card {
    align-content: center;
    justify-items: center;
    padding: clamp(24px, 5vw, 80px);
}

.cpp-test-overlay[data-variant="full"] .cpp-test-main,
.cpp-test-overlay[data-variant="full"] .cpp-test-media {
    width: min(100%, 760px);
}

.cpp-test-close {
    position: absolute;
    top: 12px;
    right: 12px;
    z-index: 2;
    width: 36px;
    height: 36px;
    padding: 0;
    color: #111827;
    font-size: 26px;
    line-height: 1;
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(17, 24, 39, 0.12);
    border-radius: 50%;
    cursor: pointer;
}

.cpp-test-media {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 220px;
    background: #e5e7eb;
    overflow: hidden;
}

.cpp-test-media img {
    display: block;
    width: 100%;
    height: 100%;
    min-height: inherit;
    object-fit: cover;
}

.cpp-test-media span {
    width: 74px;
    height: 74px;
    background: #2563eb;
    border-radius: 8px;
    box-shadow: 28px 20px 0 #0f766e, -18px -16px 0 #facc15;
}

.cpp-test-overlay[data-variant="full"] .cpp-test-media {
    min-height: 320px;
    margin-bottom: 28px;
    border-radius: 8px;
}

.cpp-test-main {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: 12px;
    min-width: 0;
    padding: clamp(24px, 4vw, 40px);
}

.cpp-test-kicker,
.cpp-test-title,
.cpp-test-description {
    margin: 0;
}

.cpp-test-kicker {
    color: #0f766e;
    font-size: 12px;
    font-weight: 700;
    line-height: 1.2;
    text-transform: uppercase;
}

.cpp-test-title {
    color: #111827;
    font-size: clamp(28px, 4vw, 46px);
    line-height: 1.08;
}

.cpp-test-overlay[data-variant="top"] .cpp-test-title,
.cpp-test-overlay[data-variant="bottom"] .cpp-test-title,
.cpp-test-overlay[data-variant="corner"] .cpp-test-title {
    font-size: clamp(22px, 3vw, 34px);
}

.cpp-test-description {
    color: #4b5563;
    font-size: 17px;
    line-height: 1.55;
}

.cpp-test-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 6px;
}

.cpp-test-cta,
.cpp-test-cancel {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0 18px;
    color: #fff;
    font-size: 16px;
    font-weight: 700;
    line-height: 1.2;
    text-decoration: none;
    border: 0;
    border-radius: 8px;
    cursor: pointer;
}

.cpp-test-cta {
    background: var(--cpp-test-button-color, #2563eb);
}

.cpp-test-cancel {
    background: var(--cpp-test-cancel-button-color, #6b7280);
}

.cpp-test-cta:hover,
.cpp-test-cta:focus,
.cpp-test-cancel:hover,
.cpp-test-cancel:focus {
    color: #fff;
    filter: brightness(0.92);
}

@media (max-width: 640px) {
    .cpp-test-overlay,
    .cpp-test-overlay[data-variant="corner"] {
        padding: 12px;
    }

    .cpp-test-card {
        grid-template-columns: 1fr;
    }

    .cpp-test-media {
        min-height: 180px;
    }

    .cpp-test-main {
        padding: 24px;
    }

    .cpp-test-title,
    .cpp-test-overlay[data-variant="top"] .cpp-test-title,
    .cpp-test-overlay[data-variant="bottom"] .cpp-test-title,
    .cpp-test-overlay[data-variant="corner"] .cpp-test-title {
        font-size: 28px;
    }
}
{% endcss %}

{% js %}
(() => {
    const fieldOptionsBySection = {{ fieldsBySection|json_encode|raw }};
    const titleFieldOptionsBySection = {{ titleFieldsBySection|json_encode|raw }};
    const fallbackFieldOptions = fieldOptionsBySection[''] || [{ label: 'Not mapped', value: '' }];
    const fallbackTitleFieldOptions = titleFieldOptionsBySection[''] || [{ label: 'Entry title', value: '__title__' }];
    const mappingFieldNames = [
        'descriptionFieldHandle',
        'imageFieldHandle',
        'ctaUrlFieldHandle',
        'ctaLabelFieldHandle',
        'cancelLabelFieldHandle'
    ];

    const getNamedInput = (name) => document.querySelector(`[name="${name}"]`) || document.querySelector(`[name$="[${name}]"]`);
    const sectionSelect = getNamedInput('sectionHandle');
    const fieldSelects = mappingFieldNames
        .map((name) => getNamedInput(name))
        .filter((field) => field);
    const titleFieldSelect = getNamedInput('titleFieldHandle');

    const replaceFieldOptions = (select, options) => {
        const currentValue = select.value;
        select.innerHTML = '';

        for (const optionConfig of options) {
            const option = document.createElement('option');
            option.value = optionConfig.value;
            option.textContent = optionConfig.label;
            select.appendChild(option);
        }

        select.value = options.some((optionConfig) => optionConfig.value === currentValue) ? currentValue : '';
    };

    const updateFieldMappingOptions = () => {
        if (!sectionSelect) {
            return;
        }

        const options = fieldOptionsBySection[sectionSelect.value] || fallbackFieldOptions;
        fieldSelects.forEach((select) => replaceFieldOptions(select, options));

        if (titleFieldSelect) {
            replaceFieldOptions(titleFieldSelect, titleFieldOptionsBySection[sectionSelect.value] || fallbackTitleFieldOptions);
        }
    };

    if (sectionSelect) {
        sectionSelect.addEventListener('change', updateFieldMappingOptions);
        updateFieldMappingOptions();
    }

    const button = document.querySelector('[data-cpp-install-defaults]');
    const actionUrl = {{ installDefaultsAction|json_encode|raw }};

    if (button) {
        button.addEventListener('click', async () => {
            button.classList.add('loading');
            button.setAttribute('disabled', 'disabled');

            const body = new FormData();
            if (Craft.csrfTokenName && Craft.csrfTokenValue) {
                body.append(Craft.csrfTokenName, Craft.csrfTokenValue);
            }

            try {
                const response = await fetch(actionUrl, {
                    method: 'POST',
                    body,
                    credentials: 'same-origin',
                    headers: {
                        Accept: 'application/json'
                    }
                });
                const data = await response.json();

                if (!response.ok || !data.success) {
                    throw new Error(data.message || 'Could not create the default popup section.');
                }

                Craft.cp.displayNotice(data.message);
                window.location.reload();
            } catch (error) {
                Craft.cp.displayError(error.message);
            } finally {
                button.classList.remove('loading');
                button.removeAttribute('disabled');
            }
        });
    }

    const testButton = document.querySelector('[data-cpp-test-modal]');
    const testOverlay = document.querySelector('[data-cpp-test-overlay]');
    const testCard = document.querySelector('.cpp-test-card');
    const testClose = document.querySelector('[data-cpp-test-close]');
    const testCta = document.querySelector('[data-cpp-test-cta]');
    const testCancel = document.querySelector('[data-cpp-test-cancel]');
    const testTitle = document.querySelector('[data-cpp-test-title]');
    const testDescription = document.querySelector('[data-cpp-test-description]');
    const testImage = document.querySelector('[data-cpp-test-image]');
    const testPlaceholder = document.querySelector('[data-cpp-test-placeholder]');
    const previewActionUrl = {{ previewAction|json_encode|raw }};
    const previewFieldNames = [
        'enabled',
        'autoInject',
        'sectionHandle',
        'titleFieldHandle',
        'descriptionFieldHandle',
        'imageFieldHandle',
        'ctaUrlFieldHandle',
        'ctaLabelFieldHandle',
        'cancelLabelFieldHandle',
        'defaultVariant',
        'randomizeVariants',
        'delaySeconds',
        'ctaLabelDefault',
        'cancelLabelDefault',
        'ctaTarget',
        'buttonColor',
        'cancelButtonColor',
        'cookieDurationDays',
        'cookieNamePrefix',
        'closeOnEsc',
        'closeOnBackdrop'
    ];

    const closeTestModal = () => {
        if (!testOverlay) {
            return;
        }

        testOverlay.hidden = true;
    };

    const previewBody = () => {
        const body = new FormData();

        if (Craft.csrfTokenName && Craft.csrfTokenValue) {
            body.append(Craft.csrfTokenName, Craft.csrfTokenValue);
        }

        for (const name of previewFieldNames) {
            const field = getNamedInput(name);
            if (!field) {
                continue;
            }

            if (field.type === 'checkbox') {
                body.append(name, field.checked ? '1' : '0');
            } else {
                body.append(name, field.value);
            }
        }

        return body;
    };

    const populateTestModal = (popup) => {
        if (!testOverlay) {
            return;
        }

        testOverlay.dataset.variant = popup.variant || 'center';

        if (testCard) {
            testCard.style.setProperty('--cpp-test-button-color', popup.buttonColor || '#2563eb');
            testCard.style.setProperty('--cpp-test-cancel-button-color', popup.cancelButtonColor || '#6b7280');
        }

        if (testTitle) {
            testTitle.textContent = popup.title || 'Untitled popup';
        }

        if (testDescription) {
            testDescription.textContent = popup.description || '';
            testDescription.hidden = !popup.description;
        }

        if (testImage && testPlaceholder) {
            if (popup.image && popup.image.url) {
                testImage.src = popup.image.url;
                testImage.alt = popup.image.alt || '';
                testImage.hidden = false;
                testPlaceholder.hidden = true;
            } else {
                testImage.removeAttribute('src');
                testImage.hidden = true;
                testPlaceholder.hidden = false;
            }
        }

        if (testCta) {
            testCta.textContent = popup.cta ? popup.cta.label : '';
            testCta.hidden = !popup.cta;
        }

        if (testCancel) {
            testCancel.textContent = popup.cancelLabel || '';
            testCancel.hidden = !popup.cancelLabel;
        }

        testOverlay.hidden = false;
    };

    const openTestModal = async () => {
        if (!testOverlay || !testButton) {
            return;
        }

        testButton.classList.add('loading');
        testButton.setAttribute('disabled', 'disabled');

        try {
            const response = await fetch(previewActionUrl, {
                method: 'POST',
                body: previewBody(),
                credentials: 'same-origin',
                headers: {
                    Accept: 'application/json'
                }
            });
            const data = await response.json();

            if (!response.ok || !data.success || !data.popup) {
                throw new Error(data.message || 'No live popup entry is available for preview.');
            }

            populateTestModal(data.popup);
        } catch (error) {
            Craft.cp.displayError(error.message);
        } finally {
            testButton.classList.remove('loading');
            testButton.removeAttribute('disabled');
        }
    };

    if (testButton) {
        testButton.addEventListener('click', openTestModal);
    }

    if (testClose) {
        testClose.addEventListener('click', closeTestModal);
    }

    if (testCancel) {
        testCancel.addEventListener('click', closeTestModal);
    }

    if (testOverlay) {
        testOverlay.addEventListener('click', (event) => {
            if (event.target === testOverlay) {
                closeTestModal();
            }
        });
    }

    document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
            closeTestModal();
        }
    });
})();
{% endjs %}
